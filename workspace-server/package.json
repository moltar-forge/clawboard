{
  "name": "clawboard-workspace-service",
  "version": "0.1.0",
  "description": "HTTP service for OpenClaw workspace file access - Clawboard sidecar",
  "main": "server.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/moltar-forge/clawboard.git"
  },
  "bugs": {
    "url": "https://github.com/moltar-forge/clawboard/issues"
  },
  "homepage": "https://github.com/moltar-forge/clawboard/tree/main/workspace-server#readme",
  "scripts": {
    "start": "node server.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --watch",
    "test:run": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "keywords": [
    "clawboard",
    "openclaw",
    "workspace",
    "file-service"
  ],
  "author": "Clawboard",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "lint-staged": {
    "*.{js,json,md}": "prettier --write"
  }
}
